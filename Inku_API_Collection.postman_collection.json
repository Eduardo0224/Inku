{
	"info": {
		"_postman_id": "inku-auth-collection-2026",
		"name": "Inku - Authentication & Collection API",
		"description": "Complete API collection for Inku app testing with authentication and manga collection management",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    console.log('User registered successfully!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "App-Token",
								"value": "{{appToken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"{{testPassword}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						},
						"description": "Register a new user. Requires App-Token header.\nEmail must be valid format, password must be 8+ characters."
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set('userToken', jsonData.token);",
									"    console.log('Login successful! Token saved to environment.');",
									"    console.log('Token:', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"var email = pm.environment.get('testEmail');",
									"var password = pm.environment.get('testPassword');",
									"var credentials = email + ':' + password;",
									"var encodedCredentials = btoa(credentials);",
									"pm.environment.set('basicAuth', 'Basic ' + encodedCredentials);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{basicAuth}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"login"
							]
						},
						"description": "Login with existing user credentials. Returns a Bearer token valid for 2 days.\nAutomatically encodes credentials to Basic Auth and saves token."
					},
					"response": []
				},
				{
					"name": "Renew Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set('userToken', jsonData.token);",
									"    console.log('Token renewed successfully!');",
									"    console.log('New Token:', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{userToken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users/renew",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"renew"
							]
						},
						"description": "Renew an existing token. Old token becomes invalid.\nAutomatically saves new token to environment."
					},
					"response": []
				}
			],
			"description": "User authentication endpoints: register, login, and token renewal"
		},
		{
			"name": "2. Collection Management",
			"item": [
				{
					"name": "Add Manga to Collection",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201 || pm.response.code === 200) {",
									"    console.log('Manga added/updated in collection successfully!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{userToken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"manga\": 42,\n    \"completeCollection\": false,\n    \"volumesOwned\": [1, 2, 3, 4, 5],\n    \"readingVolume\": 3\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/collection/manga",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"collection",
								"manga"
							]
						},
						"description": "Add or update a manga in user's collection.\nIf manga exists, it updates. If not, it creates new entry.\nExample uses manga ID 42 (Dragon Ball)."
					},
					"response": []
				},
				{
					"name": "Get User Collection",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    console.log('Collection retrieved! Total mangas:', jsonData.length);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{userToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/collection/manga",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"collection",
								"manga"
							]
						},
						"description": "Get all manga in user's collection. Returns array of manga objects with collection data.\nNot paginated."
					},
					"response": []
				},
				{
					"name": "Get Specific Manga from Collection",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    console.log('Manga details retrieved from collection!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{userToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/collection/manga/42",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"collection",
								"manga",
								"42"
							]
						},
						"description": "Get a specific manga from user's collection by manga ID.\nReturns 404 if manga not in collection."
					},
					"response": []
				},
				{
					"name": "Delete Manga from Collection",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    console.log('Manga deleted from collection successfully!');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{userToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/collection/manga/42",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"collection",
								"manga",
								"42"
							]
						},
						"description": "Delete a manga from user's collection by manga ID.\nReturns 404 if manga not in collection."
					},
					"response": []
				}
			],
			"description": "Manga collection management endpoints (requires authentication)"
		},
		{
			"name": "3. Manga Info (Public)",
			"item": [
				{
					"name": "List Mangas",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    console.log('Mangas retrieved:', jsonData.data.length);",
									"    console.log('Total in database:', jsonData.metadata.total);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/list/mangas?page=1&per=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"list",
								"mangas"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "per",
									"value": "10"
								}
							]
						},
						"description": "Get paginated list of manga. Use to find manga IDs for collection testing."
					},
					"response": []
				},
				{
					"name": "Get Manga by ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    console.log('Manga:', jsonData.title);",
									"    console.log('ID:', jsonData.id);",
									"    console.log('Volumes:', jsonData.volumes);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/search/manga/42",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"search",
								"manga",
								"42"
							]
						},
						"description": "Get detailed information about a specific manga by ID.\nExample: ID 42 = Dragon Ball"
					},
					"response": []
				},
				{
					"name": "Search Manga by Title",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    console.log('Found mangas:', jsonData.data.length);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/search/mangasContains/naruto?page=1&per=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"search",
								"mangasContains",
								"naruto"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "per",
									"value": "10"
								}
							]
						},
						"description": "Search manga by title (contains search).\nUse to find manga IDs for testing."
					},
					"response": []
				}
			],
			"description": "Public manga information endpoints (no authentication required)"
		}
	],
